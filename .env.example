# Cloud sync (Supabase)
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and the Publishable key below
#    (older dashboards call this the "anon public" key — either format works)
# 4. Run the SQL in ./supabase/schema.sql in the Supabase SQL editor
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here
